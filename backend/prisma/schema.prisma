generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Replaces User mongoose model

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // Replaces stats embedded object
  matchesPlayed Int @default(0)
  wins          Int @default(0)

  // Replaces practiceStats embedded object
  puzzlesSolved    Int @default(0)
  totalHintsUsed   Int @default(0)
  totalTimeTaken   Int @default(0)

  // Replaces stats.history array
  matchHistory   MatchHistory[]
  practiceHistory PracticeHistory[]

  @@map("users")
}

model MatchHistory {
  id     String   @id @default(uuid())
  result String   // "WIN" or "LOSS"
  date   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("match_history")
}

model PracticeHistory {
  id         String   @id @default(uuid())
  solvedAt   DateTime @default(now())
  difficulty String
  timeTaken  Int
  hintsUsed  Int

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("practice_history")
}

// Replaces Room mongoose model
// Note: board and solution are stored as JSON (2D arrays)
model Room {
  id          String   @id @default(uuid())
  roomId      String   @unique
  players     String[] // array of socket IDs
  board       Json     // [[Number]] as JSON
  solution    Json
  winner      String?
  gameStarted Boolean  @default(false)
  createdAt   DateTime @default(now())

  // userMap: socket_id → user_id stored as a separate table
  userMap RoomUserMap[]

  @@map("rooms")
}

model RoomUserMap {
  id       String @id @default(uuid())
  socketId String
  userId   String

  roomId String
  room   Room   @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@unique([roomId, socketId])
  @@map("room_user_map")
}